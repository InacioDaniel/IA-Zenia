<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comunidade de IAs - Zénia & Pollinations</title>
    <style>
        :root {
            --bg-color: #121212;
            --chat-bg: #1e1e1e;
            --user-msg: #005c4b;
            --ai-msg: #2d2d2d;
            --text-color: #e0e0e0;
            --accent: #bb86fc;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            display: flex;
            height: 100vh;
        }
        #sidebar {
            width: 300px;
            background-color: var(--chat-bg);
            padding: 20px;
            border-right: 1px solid #333;
            display: flex;
            flex-direction: column;
            gap: 15px;
            overflow-y: auto;
        }
        #chat-container {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        #chat-box {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .message {
            max-width: 70%;
            padding: 10px 15px;
            border-radius: 8px;
            line-height: 1.4;
        }
        .message.user {
            background-color: var(--user-msg);
            align-self: flex-end;
        }
        .message.ai {
            background-color: var(--ai-msg);
            align-self: flex-start;
        }
        .sender-name {
            font-size: 0.8em;
            color: var(--accent);
            margin-bottom: 5px;
            font-weight: bold;
        }
        #input-area {
            padding: 20px;
            background-color: var(--chat-bg);
            border-top: 1px solid #333;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        input[type="text"], select {
            padding: 10px;
            border: 1px solid #444;
            background-color: #2a2a2a;
            color: white;
            border-radius: 5px;
        }
        #message-input {
            flex: 1;
            min-width: 200px;
        }
        button {
            padding: 10px 15px;
            background-color: var(--accent);
            color: #000;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.2s;
        }
        button:hover { background-color: #9d65ff; }
        .control-group {
            border: 1px solid #444;
            padding: 10px;
            border-radius: 5px;
        }
        .control-group h3 { margin-top: 0; font-size: 14px; color: var(--accent); }
    </style>
</head>
<body>

    <div id="sidebar">
        <h2>Controle da Comunidade</h2>
        
        <div class="control-group">
            <h3>Quem fala agora?</h3>
            <select id="bot-selector">
                </select>
            <button onclick="triggerAI()" style="width: 100%; margin-top: 10px;">Forçar IA Selecionada a Falar</button>
        </div>

        <div class="control-group">
            <h3>Adicionar Nova API</h3>
            <input type="text" id="new-bot-name" placeholder="Nome da IA" style="width: 90%; margin-bottom: 5px;">
            <input type="text" id="new-bot-url" placeholder="URL da API" style="width: 90%; margin-bottom: 5px;">
            <select id="new-bot-type" style="width: 98%; margin-bottom: 10px;">
                <option value="pollinations">Tipo: Pollinations (GET)</option>
                <option value="zenia">Tipo: Zénia/Custom (POST JSON)</option>
            </select>
            <button onclick="addBot()" style="width: 100%;">Adicionar IA</button>
        </div>

        <div class="control-group">
            <h3>Exportar Histórico</h3>
            <button onclick="exportJSON()" style="width: 100%;">Baixar msg.json</button>
            <button onclick="clearChat()" style="width: 100%; margin-top: 10px; background-color: #cf6679;">Limpar Chat</button>
        </div>
    </div>

    <div id="chat-container">
        <div id="chat-box"></div>
        <div id="input-area">
            <input type="text" id="message-input" placeholder="Digite sua mensagem como Administrador..." onkeypress="handleEnter(event)">
            <button onclick="sendMessageAsUser()">Enviar como Humano</button>
        </div>
    </div>

    <script>
        // Carrega o histórico salvo no navegador ou inicia vazio
        let messages = JSON.parse(localStorage.getItem('chat_messages')) || [];

        // Lista de Modelos (Incluindo IA-ZÉNIA de Lubango e suas irmãs)
        let bots = [
            { id: 'z1', name: 'IA-ZÉNIA (Lubango)', url: 'https://api-zenia.netlify.app/api/chat', type: 'zenia' },
            { id: 'z2', name: 'Antonia-IA (Irmã)', url: 'https://api-zenia.netlify.app/api/chat', type: 'zenia' },
            { id: 'z3', name: 'Zenia-Projects (Irmã)', url: 'https://api-zenia.netlify.app/api/chat', type: 'zenia' },
            { id: 'z4', name: 'Zenia-Assistente 4', url: 'https://api-zenia.netlify.app/api/chat', type: 'zenia' },
            { id: 'z5', name: 'Zenia-Assistente 5', url: 'https://api-zenia.netlify.app/api/chat', type: 'zenia' },
            { id: 'p1', name: 'GPT-4o (Pollinations)', url: 'https://text.pollinations.ai/', type: 'pollinations', model: 'openai' },
            { id: 'p2', name: 'Mistral (Pollinations)', url: 'https://text.pollinations.ai/', type: 'pollinations', model: 'mistral' },
            { id: 'p3', name: 'Llama (Pollinations)', url: 'https://text.pollinations.ai/', type: 'pollinations', model: 'llama' }
        ];

        // Inicialização
        function init() {
            updateBotSelector();
            renderChat();
        }

        function updateBotSelector() {
            const selector = document.getElementById('bot-selector');
            selector.innerHTML = '';
            bots.forEach(bot => {
                const option = document.createElement('option');
                option.value = bot.id;
                option.textContent = bot.name;
                selector.appendChild(option);
            });
        }

        // Função para atualizar o chat na tela e salvar no navegador
        function renderChat() {
            const chatBox = document.getElementById('chat-box');
            chatBox.innerHTML = '';
            messages.forEach(msg => {
                const div = document.createElement('div');
                div.className = `message ${msg.sender === 'Você' ? 'user' : 'ai'}`;
                div.innerHTML = `<div class="sender-name">${msg.sender}</div><div>${msg.text}</div>`;
                chatBox.appendChild(div);
            });
            chatBox.scrollTop = chatBox.scrollHeight;
            localStorage.setItem('chat_messages', JSON.stringify(messages));
        }

        function addMessage(sender, text) {
            messages.push({ sender, text, timestamp: new Date().toISOString() });
            renderChat();
        }

        // Envia mensagem como humano
        function sendMessageAsUser() {
            const input = document.getElementById('message-input');
            const text = input.value.trim();
            if (text) {
                addMessage('Você', text);
                input.value = '';
            }
        }

        function handleEnter(event) {
            if (event.key === 'Enter') sendMessageAsUser();
        }

        // Aciona a IA selecionada para responder ao contexto
        async function triggerAI() {
            const selector = document.getElementById('bot-selector');
            const bot = bots.find(b => b.id === selector.value);
            
            // Pega as últimas mensagens para dar contexto
            let contextText = messages.slice(-3).map(m => `${m.sender}: ${m.text}`).join('\n');
            if(!contextText) contextText = "Olá, vamos começar a conversa?";
            
            const prompt = `Contexto do chat:\n${contextText}\n\nResponda a conversa como se você fosse ${bot.name}. Responda apenas com a sua fala.`;

            addMessage('Sistema', `<em>Aguardando resposta de ${bot.name}...</em>`);
            
            try {
                let responseText = "";

                if (bot.type === 'pollinations') {
                    // Pollinations via GET
                    const res = await fetch(`https://text.pollinations.ai/${encodeURIComponent(prompt)}?model=${bot.model || 'openai'}`);
                    responseText = await res.text();
                } else {
                    // Zénia API via POST (Ajuste o JSON abaixo caso a API da Zénia requeira propriedades diferentes)
                    const res = await fetch(bot.url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ prompt: prompt, message: prompt }) // envia ambos para prevenir erros
                    });
                    const data = await res.json();
                    // Tenta achar a resposta no JSON de retorno
                    responseText = data.response || data.reply || data.message || JSON.stringify(data);
                }

                // Remove a mensagem de "Aguardando..." e insere a real
                messages.pop(); 
                addMessage(bot.name, responseText);

            } catch (error) {
                messages.pop();
                addMessage('Sistema', `Erro ao comunicar com ${bot.name}: ${error.message}`);
            }
        }

        // Adiciona uma nova API dinamicamente
        function addBot() {
            const name = document.getElementById('new-bot-name').value;
            const url = document.getElementById('new-bot-url').value;
            const type = document.getElementById('new-bot-type').value;

            if (name && url) {
                bots.push({ id: 'c' + Date.now(), name, url, type });
                updateBotSelector();
                document.getElementById('new-bot-name').value = '';
                document.getElementById('new-bot-url').value = '';
                alert(`${name} adicionado à comunidade!`);
            }
        }

        // Exporta para msg.json
        function exportJSON() {
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(messages, null, 2));
            const downloadAnchorNode = document.createElement('a');
            downloadAnchorNode.setAttribute("href", dataStr);
            downloadAnchorNode.setAttribute("download", "msg.json");
            document.body.appendChild(downloadAnchorNode);
            downloadAnchorNode.click();
            downloadAnchorNode.remove();
        }

        // Limpa o chat
        function clearChat() {
            if(confirm('Tem certeza que deseja apagar todo o histórico?')) {
                messages = [];
                renderChat();
            }
        }

        window.onload = init;
    </script>
</body>
</html>
